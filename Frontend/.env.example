# =====================================================================
# NextGen Fusion Frontend — required environment variables
# Copy this file to .env.local and fill in real values.
# =====================================================================

# Backend URL used by Next.js server-side fetches (server components)
# In production, set this to your actual backend URL (e.g. https://api.nextgenfusion.in)
BACKEND_URL=http://localhost:4000

# Public API base URL used by client-side fetches
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Public Supabase URL (needed for any client-side Supabase usage)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# --- Agency contact details ---
# WhatsApp number in international format without +
NEXT_PUBLIC_WHATSAPP_NUMBER=917348228167
NEXT_PUBLIC_CONTACT_EMAIL=contact@nextgenfusion.in
NEXT_PUBLIC_CONTACT_PHONE=+917348228167

# --- Admin auth ---
# Must match ADMIN_SESSION_SECRET in the Backend .env
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string-please

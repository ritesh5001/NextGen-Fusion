# =====================================================================
# NextGen Fusion Backend — required environment variables
# Copy this file to .env and fill in real values.
# =====================================================================

PORT=4000

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,https://nextgenfusion.in,https://www.nextgenfusion.in

# --- Supabase ---
# From: Supabase project → Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend ---
# From: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=campaigns@nextgenfusion.in
RESEND_FROM_NAME=NextGen Fusion
RESEND_REPLY_TO=hello@nextgenfusion.in

# --- Admin auth ---
ADMIN_PASSWORD=your-admin-password
# Random 32+ char string used to sign session cookies. Generate one: openssl rand -base64 48
# Must match ADMIN_SESSION_SECRET in the Frontend .env
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string-please

# --- Cron security ---
# Random secret. Send as `Authorization: Bearer <CRON_SECRET>` when calling /api/cron/process-campaigns
CRON_SECRET=change-me-to-another-long-random-string

# Optional internal queue worker. Leave enabled if you want the backend
# process itself to keep sending scheduled campaign emails automatically.
CAMPAIGN_PROCESSOR_ENABLED=true
CAMPAIGN_PROCESSOR_INTERVAL_MS=30000

# --- Grok / xAI estimator ---
# From: https://console.x.ai
XAI_API_KEY=xai-your-api-key
XAI_MODEL=grok-4-1-fast-non-reasoning

# --- Booking alerts ---
BOOKING_ALERT_EMAIL=nextgenfusion.devs@gmail.com
